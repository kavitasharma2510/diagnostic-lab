{
  "name": "diagnostic-lab-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "build": "node scripts/prisma-cli.mjs generate && node scripts/install-puppeteer-chrome.mjs",
    "db:push": "node scripts/prisma-cli.mjs db push",
    "db:migrate": "node scripts/prisma-cli.mjs db push",
    "db:generate": "node scripts/prisma-cli.mjs generate",
    "db:seed": "node prisma/seed.js",
    "db:sync-cbc": "node scripts/sync-cbc-parameters.mjs",
    "db:sync-panels": "node scripts/sync-all-panels.mjs",
    "db:cleanup": "node scripts/run-data-cleanup.mjs",
    "db:studio": "prisma studio",
    "browsers:install": "node scripts/install-puppeteer-chrome.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "bwip-js": "^4.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "puppeteer": "^24.2.1",
    "qrcode": "^1.5.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "prisma": "^6.5.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
