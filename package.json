{
  "private": true,
  "workspaces": [
    "backend",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w backend\" \"npm run dev -w client\"",
    "dev:api": "npm run dev -w backend",
    "dev:web": "npm run dev -w client",
    "db:migrate": "npm run db:migrate -w backend",
    "db:seed": "npm run db:seed -w backend",
    "build": "npm run build -w client"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
